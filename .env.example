# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.

# Required for coach chat, coach hints, adaptive coach selection, and AI question generation.
# The server uses an OpenAI-style /chat/completions request body.
LLM_API_KEY=your_provider_key_here

# Optional overrides
# LLM_API_URL=https://api.moonshot.ai/v1/chat/completions
# LLM_MODEL=kimi-k2.6
# LLM_THINKING=disabled
# CERT_SLUG=genai_llms_professional
# PORT=4173
# HOST=127.0.0.1
